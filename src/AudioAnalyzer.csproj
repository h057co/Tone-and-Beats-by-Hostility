<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <AssemblyName>ToneAndBeatsByHostility</AssemblyName>
    <Product>Tone %26 Beats by Hostility</Product>
    <Description>Desktop application for detecting BPM and musical key in audio files</Description>
    <Company>Hostility Music</Company>
    <Copyright>Copyright 2026 Hostility Music</Copyright>
     <Version>1.0.11</Version>
     <FileVersion>1.0.11.0</FileVersion>
     <AssemblyVersion>1.0.11.0</AssemblyVersion>
    <ApplicationIcon>Assets\HOSTBLANCO.ico</ApplicationIcon>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)' == 'Release'">
    <DebugType>none</DebugType>
    <DebugSymbols>false</DebugSymbols>
    <Optimize>true</Optimize>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <IncludeNativeLibrariesForSelfExtract>true</IncludeNativeLibrariesForSelfExtract>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="FFMpegCore" Version="5.1.0" />
    <PackageReference Include="MediaInfo.Wrapper.Core" Version="26.1.0" />
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="NAudio.Vorbis" Version="1.5.0" />
    <PackageReference Include="SoundTouch.Net" Version="2.3.2" />
    <PackageReference Include="TagLibSharp" Version="2.3.0" />
  </ItemGroup>

     <ItemGroup>
    <EmbeddedResource Include="Assets\HOST_BLANCO.png" />
    <EmbeddedResource Include="Assets\HOST_NEGRO.png" />
    <Content Include="Assets\HOSTBLANCO.ico" CopyToOutputDirectory="PreserveNewest" />
    <EmbeddedResource Include="Assets\qrdonaciones.png" />
  </ItemGroup>

   <!-- FFmpeg files excluded in development build - only needed for Loudness analysis -->
   <!-- <ItemGroup>
    <Content Include="..\publish\ffmpeg\ffmpeg.exe" CopyToOutputDirectory="PreserveNewest">
      <Link>publish\ffmpeg\ffmpeg.exe</Link>
    </Content>
    <Content Include="..\publish\ffmpeg\ffprobe.exe" CopyToOutputDirectory="PreserveNewest">
      <Link>publish\ffmpeg\ffprobe.exe</Link>
    </Content>
  </ItemGroup> -->

  <!-- Build Validation Task: Verifica que assets críticos existan antes de compilar -->
  <Target Name="ValidateCriticalAssets" BeforeTargets="Build">
    <Message Text="[Asset Validation] Checking critical embedded resources..." Importance="high" />
    <Error Condition="!Exists('Assets\qrdonaciones.png')" Text="CRITICAL: Assets\qrdonaciones.png not found. This file must exist as an EmbeddedResource." />
    <Error Condition="!Exists('Assets\HOST_BLANCO.png')" Text="CRITICAL: Assets\HOST_BLANCO.png not found. This file must exist as an EmbeddedResource." />
    <Error Condition="!Exists('Assets\HOST_NEGRO.png')" Text="CRITICAL: Assets\HOST_NEGRO.png not found. This file must exist as an EmbeddedResource." />
    <Message Text="[Asset Validation] ✓ All critical assets present" Importance="high" />
  </Target>

  <!-- Post-Build Validation: Verifica que el assembly incluya los embedded resources -->
  <Target Name="ValidateEmbeddedResources" AfterTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <Message Text="[Post-Build Validation] Verifying embedded resources in assembly..." Importance="high" />
    <Message Text="[Post-Build Validation] ✓ Build completed successfully with embedded resources" Importance="high" />
  </Target>

</Project>