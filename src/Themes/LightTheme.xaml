<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Light Theme Colors -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#3498DB"/>
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#3498DB"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#2980B9"/>
    <SolidColorBrush x:Key="ButtonDisabledBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="ResultBoxBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#555555"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TitleBrush" Color="#3498DB"/>
    <SolidColorBrush x:Key="KeyForegroundBrush" Color="#9B59B6"/>
    <SolidColorBrush x:Key="AnalyzeButtonBrush" Color="#9B59B6"/>
    <SolidColorBrush x:Key="AnalyzeButtonHoverBrush" Color="#8E44AD"/>
    <SolidColorBrush x:Key="ProgressBarBackgroundBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="WaveformBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="WaveformBrush" Color="#3498DB"/>
    <SolidColorBrush x:Key="PlayheadBrush" Color="#E74C3C"/>
    
    <!-- Theme Name -->
    <system:String x:Key="ThemeName" xmlns:system="clr-namespace:System;assembly=mscorlib">Light</system:String>
    
</ResourceDictionary>
