<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Light Theme Colors -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#3498DB"/>
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#3498DB"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#2980B9"/>
    <SolidColorBrush x:Key="ButtonDisabledBrush" Color="#CCCCCC"/>
    <SolidColorBrush x:Key="ResultBoxBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#555555"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TitleBrush" Color="#3498DB"/>
    <SolidColorBrush x:Key="KeyForegroundBrush" Color="#9B59B6"/>
    <SolidColorBrush x:Key="AnalyzeButtonBrush" Color="#9B59B6"/>
    <SolidColorBrush x:Key="AnalyzeButtonHoverBrush" Color="#8E44AD"/>
    <SolidColorBrush x:Key="ProgressBarBackgroundBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="WaveformBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="WaveformBrush" Color="#3498DB"/>
    <SolidColorBrush x:Key="PlayheadBrush" Color="#E74C3C"/>
    
    <!-- Semantic State Brushes (Audit Fix #6 - ViewModel decoupling) -->
    <SolidColorBrush x:Key="StatusForegroundBrush" Color="#333333"/>
    <SolidColorBrush x:Key="StatusSuccessBrush" Color="#27AE60"/>
    <SolidColorBrush x:Key="StatusErrorBrush" Color="#E74C3C"/>
    <SolidColorBrush x:Key="FileNameInactiveBrush" Color="#999999"/>
    <SolidColorBrush x:Key="FileNameActiveBrush" Color="#000000"/>
    <SolidColorBrush x:Key="BpmSwappedBrush" Color="#E74C3C"/>
    
    <!-- ComboBox Specific Brushes -->
    <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ComboBoxForegroundBrush" Color="#2D2D2D"/>
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#3498DB"/>
    
    <!-- Button Styles -->
    <Style x:Key="IosButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="4" ShadowDepth="1" Opacity="0.15"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource ButtonDisabledBrush}"/>
                <Setter Property="Foreground" Value="#AAAAAA"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- iOS Analyze Button Style -->
    <Style x:Key="IosAnalyzeButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource AnalyzeButtonBrush}"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="Padding" Value="15,8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource AnalyzeButtonBrush}" BlurRadius="6" ShadowDepth="1" Opacity="0.2"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource AnalyzeButtonHoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- Theme Name -->
    <system:String x:Key="ThemeName" xmlns:system="clr-namespace:System;assembly=mscorlib">Light</system:String>
    
</ResourceDictionary>
