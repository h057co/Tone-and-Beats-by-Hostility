<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- iOS Dark Theme - Apple Style -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#000000"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#0A84FF"/>
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#0A84FF"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#409CFF"/>
    <SolidColorBrush x:Key="ButtonDisabledBrush" Color="#39393D"/>
    <SolidColorBrush x:Key="ResultBoxBackgroundBrush" Color="#1C1C1E"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8E8E93"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#38383A"/>
    <SolidColorBrush x:Key="TitleBrush" Color="#0A84FF"/>
    <SolidColorBrush x:Key="KeyForegroundBrush" Color="#BF5AF2"/>
    <SolidColorBrush x:Key="AnalyzeButtonBrush" Color="#BF5AF2"/>
    <SolidColorBrush x:Key="AnalyzeButtonHoverBrush" Color="#D768F5"/>
    <SolidColorBrush x:Key="ProgressBarBackgroundBrush" Color="#38383A"/>
    <SolidColorBrush x:Key="WaveformBackgroundBrush" Color="#1C1C1E"/>
    <SolidColorBrush x:Key="WaveformBrush" Color="#0A84FF"/>
    <SolidColorBrush x:Key="PlayheadBrush" Color="#FF453A"/>
    
    <!-- Semantic State Brushes (Audit Fix #6 - ViewModel decoupling) -->
    <SolidColorBrush x:Key="StatusForegroundBrush" Color="#8E8E93"/>
    <SolidColorBrush x:Key="StatusSuccessBrush" Color="#30D158"/>
    <SolidColorBrush x:Key="StatusErrorBrush" Color="#FF453A"/>
    <SolidColorBrush x:Key="FileNameInactiveBrush" Color="#8E8E93"/>
    <SolidColorBrush x:Key="FileNameActiveBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BpmModifiedBrush" Color="#FF453A"/>
    
    <!-- iOS Button Style -->
    <Style x:Key="IosButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="20,12"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="17"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="12"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="2" Opacity="0.3"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource ButtonDisabledBrush}"/>
                <Setter Property="Foreground" Value="#636366"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- iOS Analyze Button Style -->
    <Style x:Key="IosAnalyzeButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource AnalyzeButtonBrush}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="24,14"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="18"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="14"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect Color="#BF5AF2" BlurRadius="12" ShadowDepth="3" Opacity="0.5"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource AnalyzeButtonHoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- Theme Name -->
    <system:String x:Key="ThemeName" xmlns:system="clr-namespace:System;assembly=mscorlib">iOS Dark</system:String>
    
</ResourceDictionary>
