<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Dark Theme Colors -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#6A5ACD"/>
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#4A90D9"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#5AA0E9"/>
    <SolidColorBrush x:Key="ButtonDisabledBrush" Color="#555555"/>
    <SolidColorBrush x:Key="ResultBoxBackgroundBrush" Color="#2D2D3D"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#A0A0A0"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3D3D4D"/>
    <SolidColorBrush x:Key="TitleBrush" Color="#4A90D9"/>
    <SolidColorBrush x:Key="KeyForegroundBrush" Color="#E070DF"/>
    <SolidColorBrush x:Key="AnalyzeButtonBrush" Color="#6A5ACD"/>
    <SolidColorBrush x:Key="AnalyzeButtonHoverBrush" Color="#7A6ADD"/>
    <SolidColorBrush x:Key="ProgressBarBackgroundBrush" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="WaveformBackgroundBrush" Color="#2D2D3D"/>
    <SolidColorBrush x:Key="WaveformBrush" Color="#4A90D9"/>
    <SolidColorBrush x:Key="PlayheadBrush" Color="#FF6B6B"/>
    
    <!-- Semantic State Brushes (Audit Fix #6 - ViewModel decoupling) -->
    <SolidColorBrush x:Key="StatusForegroundBrush" Color="#666666"/>
    <SolidColorBrush x:Key="StatusSuccessBrush" Color="#64C864"/>
    <SolidColorBrush x:Key="StatusErrorBrush" Color="#FF6464"/>
    <SolidColorBrush x:Key="FileNameInactiveBrush" Color="#888888"/>
    <SolidColorBrush x:Key="FileNameActiveBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="BpmSwappedBrush" Color="#FF6B6B"/>
    
    <!-- ComboBox Specific Brushes -->
    <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="#1E1E2E"/>
    <SolidColorBrush x:Key="ComboBoxForegroundBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="ComboBoxBorderBrush" Color="#4A90D9"/>
    
    <!-- Button Styles -->
    <Style x:Key="IosButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="6" ShadowDepth="1" Opacity="0.3"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource ButtonDisabledBrush}"/>
                <Setter Property="Foreground" Value="#777777"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- iOS Analyze Button Style -->
    <Style x:Key="IosAnalyzeButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource AnalyzeButtonBrush}"/>
        <Setter Property="Foreground" Value="#FFFFFF"/>
        <Setter Property="Padding" Value="15,8"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="8"
                            Padding="{TemplateBinding Padding}">
                        <Border.Effect>
                            <DropShadowEffect Color="{DynamicResource AnalyzeButtonBrush}" BlurRadius="8" ShadowDepth="2" Opacity="0.3"/>
                        </Border.Effect>
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource AnalyzeButtonHoverBrush}"/>
            </Trigger>
        </Style.Triggers>
    </Style>
    
    <!-- Theme Name -->
    <system:String x:Key="ThemeName" xmlns:system="clr-namespace:System;assembly=mscorlib">Dark</system:String>
    
</ResourceDictionary>
