<Window x:Class="AudioAnalyzer.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:infra="clr-namespace:AudioAnalyzer.Infrastructure"
        Title="Acerca De - Tone And Beat's by Hostility"
        Height="910" Width="460"
        MinHeight="910" MinWidth="460"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        Background="{DynamicResource BackgroundBrush}"
        infra:CornerResizeBehavior.EnableOnlyCornerResize="True">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ForegroundBrush}"/>
        </Style>
        <Style x:Key="KoFiButton" TargetType="Button">
            <Setter Property="Background" Value="#9B8AC4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Padding" Value="20,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <TextBlock Text="Invítame a una cosita? Click Aquí" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A99AD4"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Viewbox Stretch="Uniform">
        <Grid Margin="5" Width="450" Height="850">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
        
        <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,10">
            <TextBlock Text="Tone &amp; Beats by Hostility" FontSize="24" FontWeight="Bold" 
                       Foreground="{DynamicResource TitleBrush}" HorizontalAlignment="Center"/>
             <TextBlock Text="Versión 1.0.5" FontSize="12" 
                        Foreground="{DynamicResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,5,0,0"/>
        </StackPanel>
        
         <Image x:Name="LogoImageAbout" Grid.Row="1" Height="50" 
                HorizontalAlignment="Center" Margin="0,5,0,15"/>
        
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" MaxHeight="250">
            <StackPanel>
                <TextBlock Text="Librerías y Módulos:" FontSize="16" FontWeight="Bold" Margin="0,0,0,15"/>
                
                <Border Background="{DynamicResource ResultBoxBackgroundBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                         <TextBlock Text="NAudio" FontWeight="Bold" FontSize="13"/>
                         <TextBlock Text="Autor: Mark Heath | Ms-PL" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                         <TextBlock FontSize="10">
                             <Hyperlink NavigateUri="https://github.com/naudio/NAudio" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">GitHub</Hyperlink>
                         </TextBlock>
                     </StackPanel>
                 </Border>
                
                <Border Background="{DynamicResource ResultBoxBackgroundBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                         <TextBlock Text="TagLibSharp" FontWeight="Bold" FontSize="13"/>
                         <TextBlock Text="Autor: mono | LGPL-2.1" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                         <TextBlock FontSize="10">
                             <Hyperlink NavigateUri="https://github.com/mono/taglib-sharp" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">GitHub</Hyperlink>
                         </TextBlock>
                     </StackPanel>
                 </Border>
                
                <Border Background="{DynamicResource ResultBoxBackgroundBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                         <TextBlock Text="SoundTouch.Net" FontWeight="Bold" FontSize="13"/>
                         <TextBlock Text="Autor: Olaf Woudenberg | LGPL-2.1" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                         <TextBlock FontSize="10">
                             <Hyperlink NavigateUri="https://github.com/owoudenberg/soundtouch.net" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">GitHub</Hyperlink>
                         </TextBlock>
                     </StackPanel>
                 </Border>
                
                <Border Background="{DynamicResource ResultBoxBackgroundBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                         <TextBlock Text="MediaInfo.Wrapper.Core" FontWeight="Bold" FontSize="13"/>
                         <TextBlock Text="Autor: MediaArea | BSD-2-Clause" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                         <TextBlock FontSize="10">
                             <Hyperlink NavigateUri="https://github.com/MediaArea/MediaInfo" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">GitHub</Hyperlink>
                         </TextBlock>
                     </StackPanel>
                 </Border>
                
                <Border Background="{DynamicResource ResultBoxBackgroundBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                         <TextBlock Text="FFMpegCore" FontWeight="Bold" FontSize="13"/>
                         <TextBlock Text="Autor: indexis | LGPL-2.1" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                         <TextBlock FontSize="10">
                             <Hyperlink NavigateUri="https://github.com/rosenbjerg/FFMpegCore" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">GitHub</Hyperlink>
                         </TextBlock>
                     </StackPanel>
                 </Border>
                
                <Border Background="{DynamicResource ResultBoxBackgroundBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                         <TextBlock Text="FFmpeg" FontWeight="Bold" FontSize="13"/>
                         <TextBlock Text="FFmpeg Team | GPL-3.0" FontSize="10" Foreground="{DynamicResource TextSecondaryBrush}"/>
                         <TextBlock FontSize="10">
                             <Hyperlink NavigateUri="https://ffmpeg.org" RequestNavigate="Hyperlink_RequestNavigate" Foreground="{DynamicResource AccentBrush}">ffmpeg.org</Hyperlink>
                         </TextBlock>
                     </StackPanel>
                 </Border>
            </StackPanel>
        </ScrollViewer>
        
        <TextBlock Grid.Row="3" FontSize="12" 
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   TextAlignment="Center"
                   TextWrapping="Wrap"
                   Margin="0,15,0,10"
                   Padding="15,0">
            Este proyecto nació de las ganas de compartir algo útil con ustedes. Si te gusta lo que ves y quieres invitarme a un café (o a un cable nuevo), tu donación me motiva a seguir innovando.
        </TextBlock>
        
        <Button Grid.Row="4" Style="{StaticResource KoFiButton}" 
                HorizontalAlignment="Center" 
                Margin="0,0,0,15"
                Click="KoFiButton_Click"/>
        
        <Image x:Name="QrImage" Grid.Row="5" 
               Height="280" 
               HorizontalAlignment="Center" 
               Margin="0,0,0,15"
               RenderOptions.BitmapScalingMode="HighQuality"/>
        
        <StackPanel Grid.Row="6" HorizontalAlignment="Center" Margin="0,0,0,15">
            <TextBlock Text="www.hostilitymusic.com" FontSize="14" 
                       Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" Cursor="Hand"/>
            <TextBlock Text="info@hostilitymusic.com" FontSize="12" 
                       Foreground="{DynamicResource TextSecondaryBrush}" 
                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
        </StackPanel>
        
        <TextBlock Grid.Row="7" FontSize="11" 
                   Foreground="{DynamicResource TextSecondaryBrush}" 
                   HorizontalAlignment="Center" 
                   Margin="0,5,0,20"
                   TextWrapping="Wrap"
                   TextAlignment="Center">
            © 2026 Hostility Music. www.hostilitymusic.com. Todos los derechos reservados.
        </TextBlock>
        
        <Button Grid.Row="8" Content="Cerrar" HorizontalAlignment="Center" 
                Width="120" Padding="0,10" FontSize="13" Click="CloseButton_Click"/>
    </Grid>
    </Viewbox>
</Window>
