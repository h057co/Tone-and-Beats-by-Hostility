<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- Blue Theme Colors -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0D1B2A"/>
    <SolidColorBrush x:Key="ForegroundBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="AccentBrush" Color="#00B4D8"/>
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#00B4D8"/>
    <SolidColorBrush x:Key="ButtonHoverBrush" Color="#48CAE4"/>
    <SolidColorBrush x:Key="ButtonDisabledBrush" Color="#1B263B"/>
    <SolidColorBrush x:Key="ResultBoxBackgroundBrush" Color="#1B263B"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#B3E5FC"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#1B263B"/>
    <SolidColorBrush x:Key="TitleBrush" Color="#00B4D8"/>
    <SolidColorBrush x:Key="KeyForegroundBrush" Color="#E070DF"/>
     <SolidColorBrush x:Key="AnalyzeButtonBrush" Color="#7B68EE"/>
     <SolidColorBrush x:Key="AnalyzeButtonHoverBrush" Color="#9B8BFF"/>
    <SolidColorBrush x:Key="ProgressBarBackgroundBrush" Color="#0D1B2A"/>
    <SolidColorBrush x:Key="WaveformBackgroundBrush" Color="#1B263B"/>
    <SolidColorBrush x:Key="WaveformBrush" Color="#48CAE4"/>
    <SolidColorBrush x:Key="PlayheadBrush" Color="#FF6B6B"/>
    
    <!-- Semantic State Brushes (Audit Fix #6 - ViewModel decoupling) -->
    <SolidColorBrush x:Key="StatusForegroundBrush" Color="#7A8BA0"/>
    <SolidColorBrush x:Key="StatusSuccessBrush" Color="#64C864"/>
    <SolidColorBrush x:Key="StatusErrorBrush" Color="#FF6464"/>
    <SolidColorBrush x:Key="FileNameInactiveBrush" Color="#7A8BA0"/>
    <SolidColorBrush x:Key="FileNameActiveBrush" Color="#E0E0E0"/>
    <SolidColorBrush x:Key="BpmModifiedBrush" Color="#FF6B6B"/>
    
    <!-- Theme Name -->
    <system:String x:Key="ThemeName" xmlns:system="clr-namespace:System;assembly=mscorlib">Blue</system:String>
    
</ResourceDictionary>
